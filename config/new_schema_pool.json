  {
    "id": "a6a0d78a-f20d-47fc-b173-269fbf8e9308",
    "serial": 7,
    "name": "Think_DPO_SFT",
    "description": "La struttura DPO richiede che ogni sample abbia un prompt (la conversazione fino all'ultimo turno utente) e una coppia di risposte. Il campo messages diventa il prompt, mentre le risposte gold/wrong sono oggetti separati con content + think. Il prompt è tutto ciò che precede la risposta da confrontare. In un setting multi-turn, il prompt può essere una conversazione intera fino all'ultimo turno USER. Le due risposte (gold/wrong) sono solo l'ultimo turno ASSISTANT da confrontare.",
    "schema": {
      "type": "object",
      "$schema": "http://json-schema.org/draft-07/schema#",
      "required": ["messages", "responses", "_lang", "_dataset_path", "_subpath", "_filename", "_dataset_name", "_id_hash"],
      "properties": {
        "_lang": { "type": "string", "default": "un", "maxLength": 2 },
        "_id_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "_subpath": { "type": "string", "minLength": 1 },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["role", "content", "think"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string", "enum": ["USER", "ASSISTANT", "SYSTEM"] },
              "think": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
              "content": { "anyOf": [{ "type": "string", "minLength": 1 }] }
            }
          }
        },
        "_filename": { "type": "string", "minLength": 1 },
        "responses": {
          "type": "object",
          "required": ["gold", "wrong"],
          "properties": {
            "gold": {
              "type": "object",
              "required": ["content", "think"],
              "additionalProperties": false,
              "properties": {
                "think": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
                "content": { "type": "string", "minLength": 1 }
              }
            },
            "wrong": {
              "type": "object",
              "required": ["content", "think"],
              "additionalProperties": false,
              "properties": {
                "think": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
                "content": { "type": "string", "minLength": 1 }
              }
            }
          },
          "additionalProperties": false
        },
        "_dataset_name": { "type": "string", "minLength": 1 },
        "_dataset_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "version": "1.0.1",
    "issued": "2026-04-02T15:01:11.776236+02:00",
    "modified": "2026-04-02T15:02:37.404970+02:00"
  },
