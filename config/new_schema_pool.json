  {
    "id": "3df02834-896d-466c-a082-0274e9254b99",
    "serial": 1,
    "name": "pretraining_schema_template",
    "description": "Schema standard per dataset di pretraining, include campi per percorso dataset, sottopercorso, nome file, lingua, formato, distribuzione e hash identificativo.",
    "schema": {
      "type": "object",
      "$schema": "http://json-schema.org/draft-07/schema#",
      "required": ["id", "text", "_dataset_name", "_id_hash", "_dataset_path", "_subpath", "_filename", "_lang"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "_lang": { "type": "string", "default": "un", "maxLength": 2 },
        "_id_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "_subpath": { "type": "string", "minLength": 1 },
        "_filename": { "type": "string", "minLength": 1 },
        "_dataset_name": { "type": "string", "minLength": 1 },
        "_dataset_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "version": "1.0",
    "issued": "2026-03-24T17:42:47.624644+01:00",
    "modified": "2026-03-24T17:42:47.624644+01:00"
  },
  {
    "id": "3df02834-896d-466c-a082-0274e9254b95",
    "serial": 2,
    "name": "SFT_Chat_Template",
    "description": "Schema standard per conversazioni multi-turno con SYSTEM, supporta messaggi, ruoli (USER/ASSISTANT/SYSTEM), contesto (context), ragionamento interno (think) e chiamate a funzioni (functioncall).",
    "schema": {
      "type": "object",
      "$schema": "http://json-schema.org/draft-07/schema#",
      "required": ["messages", "_lang", "_dataset_path", "_subpath", "_filename", "_dataset_name", "_id_hash"],
      "properties": {
        "_lang": { "type": "string", "default": "un", "maxLength": 2 },
        "system": { "type": ["string", "null"] },
        "context": { "type": ["string", "null"] },
        "_id_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "_subpath": { "type": "string", "minLength": 1 },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["content", "role", "think", "functioncall", "context"],
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string", "enum": ["USER", "ASSISTANT", "SYSTEM"] },
              "think": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
              "content": { "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] },
              "context": { "type": ["string", "null"] },
              "functioncall": {
                "anyOf": [
                  { "type": "null" },
                  {
                    "type": "object",
                    "required": ["payload", "response"],
                    "additionalProperties": false,
                    "properties": {
                      "payload": { "type": "string", "minLength": 1 },
                      "response": { "type": "string", "minLength": 1 }
                    }
                  }
                ]
              }
            }
          }
        },
        "_filename": { "type": "string", "minLength": 1 },
        "_dataset_name": { "type": "string", "minLength": 1 },
        "_dataset_path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "version": "1.0.2",
    "issued": "2026-03-24T17:42:47.624644+01:00",
    "modified": "2026-04-02T12:55:30.908600+02:00"
  },
